rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isCaretaker() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'caretaker';
    }

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // --- CONFIGURATION COLLECTIONS (LONG-TERM) ---

    match /cfg_acupuncture_points/{pointId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /cfg_protocols/{protocolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_measures/{measureId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /cfg_problems/{problemId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /cfg_questionnaires/{questionnaireId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_app_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_translations/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // --- REFACTORED PATIENT COLLECTIONS ---

    // 1. Personal Details
    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 2. Medical Data (Singleton per patient)
    match /patient_medical_data/{patientId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 3. Questionnaire Responses (Multiple per patient)
    match /questionnaire_responses/{responseId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 4. Treatments (Multiple per patient)
    match /treatments/{treatmentId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 5. Measured Values (Multiple per patient)
    match /measured_values/{readingId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 6. Feedback Sessions (Unauthenticated access for patients)
    match /feedback_sessions/{sessionId} {
      // Patients can only read their pending session docs
      allow read: if resource.data.status == 'pending';
      // Patients can only update the session once to submit feedback
      allow update: if resource.data.status == 'pending' 
                   && request.resource.data.status == 'completed'
                   && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['responses', 'status', 'completedAt', 'feedbackText']);
      
      // Admin/Caretaker has full control
      allow read, write: if isCaretaker() || isAdmin();
    }
  }
}
