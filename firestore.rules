rules_version = '2';
// Rules updated with null-safety checks for non-existent documents.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isCaretaker() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'caretaker';
    }

    function isAdmin() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isAuthenticated() && (role == 'admin' || role == 'superadmin');
    }

    function canImpersonate() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.canImpersonate == true
      );
    }

    function canReadPatientData(patientId) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/patients/$(patientId)).data.caretakerId == request.auth.uid ||
        canImpersonate()
      );
    }
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        canImpersonate() ||
        ( (isCaretaker() || isAdmin()) && (resource == null || resource.data.role != 'patient') )
      );
      // Only superadmins can change roles or impersonation flags.
      // Regular users can only update their own profile EXCEPT for those fields.
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'caretaker' && !('canImpersonate' in request.resource.data);
      allow update: if isAuthenticated() && (
        isSuperAdmin() || (
          request.auth.uid == userId && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'canImpersonate'])
        )
      );
      allow delete: if isSuperAdmin();
    }

    // --- CONFIGURATION COLLECTIONS (LONG-TERM) ---

    match /cfg_acupuncture_points/{pointId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /cfg_protocols/{protocolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_measures/{measureId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /cfg_problems/{problemId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /cfg_questionnaires/{questionnaireId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_app_config/{configId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /cfg_secrets/{secretId} {
        allow write: if isAdmin();
    }

    // --- FIXED CONFIGURATION TRANSLATIONS ---
    match /cfg_translations/{document=**} {
      // 1. Every authenticated user must be able to read language files to load the UI
      allow read: if isAuthenticated();
      
      // 2. Admins/Superadmins retain full permissions to modify, fix, or delete records directly
      allow write: if isAdmin();
      
      // 3. Automated frontend translation components (T.tsx) can ONLY append missing strings.
      // They are explicitly blocked from modifying (updating) or purging (deleting) existing caches.
      allow create: if isAuthenticated();
    }

    // --- REFACTORED PATIENT COLLECTIONS ---

    function isPatientCaretaker(patientId) {
      return (isCaretaker() || isAdmin()) && get(/databases/$(database)/documents/patients/$(patientId)).data.caretakerId == request.auth.uid;
    }

    // 1. Personal Details
    match /patients/{patientId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.get('caretakerId', null) == request.auth.uid || canImpersonate());
      allow create: if (isCaretaker() || isAdmin()) && request.resource.data.caretakerId == request.auth.uid;
      allow update, delete: if (isCaretaker() || isAdmin()) && resource.data.caretakerId == request.auth.uid;
    }

    // 2. Medical Data (Singleton per patient)
    match /patient_medical_data/{patientId} {
      allow read: if canReadPatientData(patientId);
      allow write: if isPatientCaretaker(patientId);
    }

    // 2a. Patient Documents (subcollection of medical data)
    match /patient_medical_data/{patientId}/documents/{docId} {
      allow read: if canReadPatientData(patientId);
      allow write: if isPatientCaretaker(patientId);
    }

    // 3. Questionnaire Responses (Multiple per patient)
    match /questionnaire_responses/{responseId} {
      allow read: if resource == null || canReadPatientData(resource.data.patientId);
      allow create: if isPatientCaretaker(request.resource.data.patientId);
      allow update, delete: if isPatientCaretaker(resource.data.patientId);
    }

    // 4. Treatments (Multiple per patient)
    match /treatments/{treatmentId} {
      allow read: if resource == null || canReadPatientData(resource.data.patientId);
      allow create: if isPatientCaretaker(request.resource.data.patientId);
      allow update, delete: if isPatientCaretaker(resource.data.patientId);
    }

    // 5. Measured Values (Multiple per patient)
    match /measured_values/{readingId} {
      allow read: if resource == null || canReadPatientData(resource.data.patientId);
      allow create: if isPatientCaretaker(request.resource.data.patientId);
      allow update, delete: if isPatientCaretaker(resource.data.patientId);
    }
    
    match /app_audit_log/{docId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /feedback_sessions/{sessionId} {
      allow get: if true;
      allow list: if isAuthenticated() && canReadPatientData(resource.data.patientId);
      allow create: if isPatientCaretaker(request.resource.data.patientId);
      allow update: if (resource.data.status == 'pending' 
               && request.resource.data.status == 'completed'
               && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['responses', 'status', 'completedAt', 'feedbackText', 'event']))
               || isPatientCaretaker(resource.data.patientId);
      allow delete: if isPatientCaretaker(resource.data.patientId);
    }
  }
}
