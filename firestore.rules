rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isCaretaker() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'caretaker';
    }

    function isAdmin() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isAuthenticated() && (role == 'admin' || role == 'superadmin');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Only superadmins can change roles or impersonation flags.
      // Regular users can only update their own profile EXCEPT for those fields.
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'caretaker' && !('canImpersonate' in request.resource.data);
      allow update: if isAuthenticated() && (
        isSuperAdmin() || (
          request.auth.uid == userId && 
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'canImpersonate'])
        )
      );
      allow delete: if isSuperAdmin();
    }

    // --- CONFIGURATION COLLECTIONS (LONG-TERM) ---

    match /cfg_acupuncture_points/{pointId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /cfg_protocols/{protocolId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_measures/{measureId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /cfg_problems/{problemId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
    }

    match /cfg_questionnaires/{questionnaireId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_app_config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /cfg_translations/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- REFACTORED PATIENT COLLECTIONS ---

    // 1. Personal Details
    match /patients/{patientId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 2. Medical Data (Singleton per patient)
    match /patient_medical_data/{patientId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 3. Questionnaire Responses (Multiple per patient)
    match /questionnaire_responses/{responseId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 4. Treatments (Multiple per patient)
    match /treatments/{treatmentId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }

    // 5. Measured Values (Multiple per patient)
    match /measured_values/{readingId} {
      allow read: if isAuthenticated();
      allow write: if isCaretaker() || isAdmin();
    }
    
    match /feedback_sessions/{sessionId} {
  	// Allow the patient to read their specific session if it's still pending
  	allow get: if resource.data.status == 'pending';
  
  	// Allow the patient to update only the responses and status to 'completed'
  	allow update: if resource.data.status == 'pending' 
               && request.resource.data.status == 'completed'
               && request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['responses', 'status', 'completedAt', 'feedbackText']);
		}
  }
}
