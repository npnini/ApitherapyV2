{
  "compilerOptions": {
    "skipLibCheck": true, // 👈 Forces TS to ignore type declaration mismatches inside node_modules
    "skipDefaultLibCheck": true, // 👈 Protects standard library definitions
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017"
  },
  "compileOnSave": true,
  "include": [
    "src"
  ]
}