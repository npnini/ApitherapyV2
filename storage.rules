rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow any authenticated user to read and write to the Points folder
    match /Points/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    // Allow any authenticated user to read and write to the Protocols folder
    match /Protocols/{allPaths=**} {
        allow read, write: if request.auth != null;
    }
       // Allow any authenticated user to read and write to the Measures folder
    match /Measures/{allPaths=**} {
        allow read, write: if request.auth != null;
    }
       // Allow any authenticated user to read and write to the Problems folder
    match /Problems/{allPaths=**} {
        allow read, write: if request.auth != null;
    }
       // Allow any authenticated user to read and write to the Patients folder
    match /Patients/{allPaths=**} {
        allow read, write: if request.auth != null;
    }
           // Allow any authenticated user to read and write to the App_config folder
    match /App_config/{allPaths=**} {
        allow read, write: if request.auth != null;
    }
  }
}
     